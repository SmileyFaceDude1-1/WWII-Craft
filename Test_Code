<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>WWII Combination Game</title>
  <style>
    body { font-family: Arial, sans-serif; padding: 20px; background:#111; color:#f5f5f5; }
    h1 { margin-bottom: 5px; }
    .card { background:#222; padding:15px; margin:10px 0; border-radius:8px; }
    select { margin:5px 0; padding:5px; width:100%; }
    button { margin-top:10px; padding:8px 12px; cursor:pointer; }
    #result { margin-top:10px; font-weight:bold; }
    #score { margin-top:10px; }
  </style>
</head>
<body>
  <h1>WWII Combination Game</h1>
  <p>Match the correct <b>Year</b>, <b>Alliance/Country</b>, and <b>Outcome</b> for the event.</p>

  <div class="card">
    <div><b>Event:</b> <span id="eventName"></span></div>

    <label>Year:</label>
    <select id="yearSelect"></select>

    <label>Alliance / Country:</label>
    <select id="sideSelect"></select>

    <label>Outcome / Key Idea:</label>
    <select id="outcomeSelect"></select>

    <button onclick="checkAnswer()">Check</button>
    <button onclick="nextQuestion()">Next</button>

    <div id="result"></div>
    <div id="score"></div>
  </div>

  <script>
    // --- DATA: edit these to match your Canva slides ---
    const combos = [
      {
        event: "D-Day",
        year: "1944",
        side: "Allies",
        outcome: "Opened Western Front in Europe"
      },
      {
        event: "Pearl Harbor",
        year: "1941",
        side: "United States",
        outcome: "U.S. enters WWII"
      },
      {
        event: "Battle of Stalingrad",
        year: "1942–1943",
        side: "Soviet Union",
        outcome: "Turning point on Eastern Front"
      },
      {
        event: "Hiroshima Bombing",
        year: "1945",
        side: "Japan",
        outcome: "Led to Japan’s surrender"
      }
    ];

    // Build option pools from data
    const years = [...new Set(combos.map(c => c.year))];
    const sides = [...new Set(combos.map(c => c.side))];
    const outcomes = [...new Set(combos.map(c => c.outcome))];

    let currentIndex = 0;
    let score = 0;

    const eventName = document.getElementById("eventName");
    const yearSelect = document.getElementById("yearSelect");
    const sideSelect = document.getElementById("sideSelect");
    const outcomeSelect = document.getElementById("outcomeSelect");
    const resultDiv = document.getElementById("result");
    const scoreDiv = document.getElementById("score");

    function shuffle(array) {
      for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
      return array;
    }

    function fillSelect(select, options) {
      select.innerHTML = "";
      options.forEach(opt => {
        const o = document.createElement("option");
        o.value = opt;
        o.textContent = opt;
        select.appendChild(o);
      });
    }

    function loadQuestion() {
      const combo = combos[currentIndex];
      eventName.textContent = combo.event;

      // Shuffle options so it's not always in order
      fillSelect(yearSelect, shuffle([...years]));
      fillSelect(sideSelect, shuffle([...sides]));
      fillSelect(outcomeSelect, shuffle([...outcomes]));

      resultDiv.textContent = "";
      scoreDiv.textContent = "Score: " + score;
    }

    function checkAnswer() {
      const combo = combos[currentIndex];
      const y = yearSelect.value;
      const s = sideSelect.value;
      const o = outcomeSelect.value;

      if (y === combo.year && s === combo.side && o === combo.outcome) {
        resultDiv.textContent = "Correct!";
        resultDiv.style.color = "#4caf50";
        score += 10;
      } else {
        resultDiv.textContent =
          "Not quite. Correct combo: " +
          combo.year + " | " + combo.side + " | " + combo.outcome;
        resultDiv.style.color = "#ff5252";
        score -= 5;
      }
      scoreDiv.textContent = "Score: " + score;
    }

    function nextQuestion() {
      currentIndex = (currentIndex + 1) % combos.length;
      loadQuestion();
    }

    // Start game
    loadQuestion();
  </script>
</body>
</html>
